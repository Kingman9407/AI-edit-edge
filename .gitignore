# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local LLM models and weights
trainer/SmolLM2-135M-Instruct/
trainer/fine_tuned_smollm/
trainer/__pycache__/
trainer/logs/
*.safetensors
*.bin
*.pt
*.pth
*.pyc

# ONNX intermediate pipeline workspaces
trainer/*_temp_raw/
trainer/*_optimized/
trainer/*_quantized/

# Keep only the final high-performance ONNX model metadata (not the large binary model.onnx)
!trainer/fine_tuned_smollm_onnx/
!trainer/fine_tuned_smollm_onnx/**
*.onnx
/public/models/

# Hugging Face & Vercel Blob test scripts
test_hf.js
test_fetch.js
test_url.js

